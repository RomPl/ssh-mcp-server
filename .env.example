# SSH MCP Server Configuration (Example)
# Скопируйте в .env и заполните реальными значениями.

# ── HTTP Server ───────────────────────────────────────────────────────────────
HTTP_PORT=3003
HTTP_HOST=127.0.0.1
PUBLIC_BASE_URL=https://mcp.yourdomain.com

# ── OAuth (Google Identity Provider) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL=you@example.com

# ── Секреты ──────────────────────────────────────────────────────────────────
# Пример генерации: openssl rand -hex 32
JWT_SECRET=change-me
SESSION_SECRET=change-me
OAUTH_CODE_SECRET=change-me

# ── Custom GPT Actions (static client chatgpt) ───────────────────────────────
# Если заданы все три — для client_id=chatgpt разрешается authorization code flow без обязательного PKCE.
CHATGPT_CLIENT_ID=chatgpt
CHATGPT_CLIENT_SECRET=change-me-long-random-secret
CHATGPT_REDIRECT_URI=https://chat.openai.com/aip/g-<your-gpt-id>/oauth/callback

# ── SSH defaults ─────────────────────────────────────────────────────────────
SSH_DEFAULT_HOST=127.0.0.1
SSH_DEFAULT_PORT=22
SSH_DEFAULT_USER=root
SSH_KEY_PATH=~/.ssh/id_ed25519

# ── Ограничение команд (опционально) ─────────────────────────────────────────
# Пусто = разрешены все команды
ALLOWED_COMMANDS=
COMMAND_TIMEOUT=30
