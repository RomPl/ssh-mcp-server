# ══════════════════════════════════════════════════════════════════════════════
# SSH MCP Server Configuration (Example)
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# ── HTTP Server Settings ──────────────────────────────────────────────────────
HTTP_PORT=3003
HTTP_HOST=127.0.0.1
PUBLIC_BASE_URL=https://mcp.yourdomain.com

# ── OAuth 2.1 Authentication (Google Identity Provider) ───────────────────────
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL=you@example.com

# ── Security Secrets ──────────────────────────────────────────────────────────
# Generate strong random strings for these secrets:
# You can use: openssl rand -hex 32

# JWT signing secret (HS256)
JWT_SECRET=change-me-to-random-64-char-string

# Session middleware secret (FastAPI)
SESSION_SECRET=change-me-to-random-64-char-string

# OAuth authorization code signing secret (HMAC-SHA256)
OAUTH_CODE_SECRET=change-me-to-random-64-char-string

# Legacy API key protection (deprecated, OAuth is preferred)
MCP_API_KEY=change-me-to-random-string

# ── SSH Connection Defaults ───────────────────────────────────────────────────
SSH_DEFAULT_HOST=127.0.0.1
SSH_DEFAULT_PORT=22
SSH_DEFAULT_USER=root

# Key-based authentication (recommended)
SSH_KEY_PATH=~/.ssh/id_ed25519
# Passphrase for encrypted key (leave empty if none)
# SSH_KEY_PASSPHRASE=

# Password authentication (fallback, less secure)
# SSH_DEFAULT_PASSWORD=

# ── Command Execution Security ────────────────────────────────────────────────
# Comma-separated list of allowed base commands (empty = allow all)
# Example: ls,cat,grep,ps,df,free,uptime,systemctl
ALLOWED_COMMANDS=

# SSH command timeout in seconds
COMMAND_TIMEOUT=30
